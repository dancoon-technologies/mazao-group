# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.103

# Database (leave empty for SQLite)
DATABASE_URL=

# S3-compatible object storage for uploads (leave bucket empty = local media/ folder in dev).
# Works with AWS S3 or providers like DigitalOcean Spaces (set endpoint below).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
# Optional: custom endpoint for S3-compatible APIs, e.g. https://nyc3.digitaloceanspaces.com
AWS_S3_ENDPOINT_URL=

# CORS (comma-separated origins, e.g. http://localhost:3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email via Next.js (optional): backend POSTs to the web app; web sends with Nodemailer.
# Use the same secret as web INTERNAL_MAIL_SECRET. If unset, Django sends mail via SMTP below.
WEB_MAIL_API_URL=
WEB_MAIL_INTERNAL_SECRET=
