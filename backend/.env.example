# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.103

# Database (leave empty for SQLite)
DATABASE_URL=

# DigitalOcean Spaces for uploads (leave bucket empty = local backend/media/ in dev).
# django-storages maps these into Django’s AWS_* settings for boto3 (S3-compatible API).
#
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=
DO_SPACES_BUCKET_NAME=
DO_SPACES_REGION=fra1
DO_SPACES_MEDIA_PREFIX=media
DO_SPACES_ENDPOINT_URL=
DO_SPACES_CDN_DOMAIN=

# CORS (comma-separated origins, e.g. http://localhost:3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Public web app URL (used in staff invite / resend-credentials emails for "Sign in here:").
# Set to your production login URL in deployment, e.g. https://app.example.com/login
FRONTEND_LOGIN_URL=http://localhost:3000/login

# Email via Next.js (optional): backend POSTs to the web app; web sends with Nodemailer.
# Use the same secret as web INTERNAL_MAIL_SECRET. If unset, Django sends mail via SMTP below.
WEB_MAIL_API_URL=
WEB_MAIL_INTERNAL_SECRET=
