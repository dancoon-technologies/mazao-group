# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.103

# Database (leave empty for SQLite)
DATABASE_URL=

# DigitalOcean Spaces for uploads (leave bucket empty = local backend/media/ in dev).
# django-storages maps these into Django’s AWS_* settings for boto3 (S3-compatible API).
#
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=
DO_SPACES_BUCKET_NAME=
DO_SPACES_REGION=fra1
DO_SPACES_MEDIA_PREFIX=media
DO_SPACES_ENDPOINT_URL=
DO_SPACES_CDN_DOMAIN=
# false (recommended): public HTTPS URLs for media so cached API/sync data keeps working.
# true: presigned URLs (expire; do not store long-term in offline DB unless you re-sync often).
AWS_QUERYSTRING_AUTH=false

# CORS (comma-separated origins, e.g. http://localhost:3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email via Next.js (optional): backend POSTs to /api/internal/mail; the Next server sends with Nodemailer.
# WEB_MAIL_INTERNAL_SECRET must match web INTERNAL_MAIL_SECRET. The web deployment also needs
# SMTP_HOST, SMTP_USER, SMTP_PASSWORD (see web/.env.example). If web mail fails, Django falls back to SMTP_* below.
WEB_MAIL_API_URL=
WEB_MAIL_INTERNAL_SECRET=
